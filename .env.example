# Copy to .env for local dev; on the droplet put a chmod-600 copy at /etc/workouts.env.
PORT=8787
HOST=127.0.0.1

# openssl rand -hex 32
SESSION_SECRET=

# node scripts/hash-password.js
PASSWORD_HASH=

# Absolute path in prod; relative is fine for local dev.
DB_PATH=./data/workouts.db

NODE_ENV=development
